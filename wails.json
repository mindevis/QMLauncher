{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "QMLauncher",
  "outputfilename": "QMLauncher-windows-amd64",
  "builddir": "build",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {"name": "QMLauncher Team"},
  "info": {
    "productName": "QMLauncher",
    "productVersion": "v1.0.0",
    "protocols": [
      {
        "scheme": "qmlauncher",
        "description": "QMLauncher Connect Protocol",
        "role": "Editor"
      }
    ]
  },
  "windows": {"icon": "assets/icon.png"},
  "webview": {"darkMode": true},
  "preBuildHooks": {"*/*": "sh ../../scripts/prepare-appicon.sh"}
}
